{
  "schema_version": "1.0",
  "owner": "leaf-test-author",
  "default_platform": "openharmony",
  "entrypoints": {
    "new_case": "/leaf-new-case <domain> \"<teststep>\"",
    "resume": "/leaf-resume <run_id>",
    "batch": "/leaf-batch <batch_id> [--run-id <run_id>...]",
    "report": "/leaf-report <run_id|batch_id>",
    "python_module": "python3 -m tools.leaf_author",
    "list_runs": "python3 -m tools.leaf_author list-runs",
    "inspect_run": "python3 -m tools.leaf_author inspect-run <run_id>",
    "create_batch": "python3 -m tools.leaf_author create-batch <batch_id> --run-id <run_id>",
    "list_batches": "python3 -m tools.leaf_author list-batches",
    "inspect_batch": "python3 -m tools.leaf_author inspect-batch <batch_id>",
    "resume_batch": "python3 -m tools.leaf_author resume-batch <batch_id> --auto-safe",
    "report_run": "python3 -m tools.leaf_author report-run <run_id>",
    "report_batch": "python3 -m tools.leaf_author report-batch <batch_id>"
  },
  "context_policy": {
    "run_listing": "lightweight_summaries",
    "run_inspection": "single_run_context_slice",
    "run_report": "summary_plus_existing_evidence_paths",
    "batch_listing": "lightweight_batch_summaries",
    "batch_inspection": "batch_summary_without_artifact_duplication",
    "batch_report": "batch_summary_then_one_run_report",
    "artifact_loading": "on_demand",
    "attention_boundary": "one_active_run"
  },
  "resume_policy": {
    "auto_safe_flag": "--auto-safe",
    "safe_local_actions": [
      "validate_pytest_draft",
      "run_pytest_draft",
      "collect_gui_context",
      "record_experience",
      "export_team_knowledge"
    ],
    "never_auto_cross": [
      "first_plan_confirmation",
      "real_device_confirmation"
    ]
  },
  "phases": {
    "plan": {
      "user_checkpoint": "first_plan_confirmation",
      "auto_safe": false,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "plan"
      ],
      "user_loop": {
        "position": "approve_plan",
        "required_input": "confirm or revise plan"
      },
      "allowed_artifacts": [
        "workflow",
        "plan",
        "device_probe"
      ],
      "next_action": "present_plan_for_confirmation",
      "batch_focus_priority": 60
    },
    "pytest_draft": {
      "user_checkpoint": null,
      "auto_safe": true,
      "agent_owner": "tools.leaf_author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "case",
        "pytest"
      ],
      "user_loop": {
        "position": "observe_safe_local_progress",
        "required_input": ""
      },
      "allowed_artifacts": [
        "case",
        "pytest"
      ],
      "next_action": "validate_pytest_draft",
      "batch_focus_priority": 10
    },
    "hypium_draft": {
      "user_checkpoint": null,
      "auto_safe": true,
      "agent_owner": "tools.leaf_author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "case",
        "pytest",
        "hypium"
      ],
      "user_loop": {
        "position": "observe_safe_local_progress",
        "required_input": ""
      },
      "allowed_artifacts": [
        "case",
        "pytest",
        "hypium"
      ],
      "next_action": "validate_pytest_draft",
      "batch_focus_priority": 10
    },
    "validated": {
      "user_checkpoint": null,
      "auto_safe": true,
      "agent_owner": "tools.leaf_author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "validation"
      ],
      "user_loop": {
        "position": "observe_safe_local_progress",
        "required_input": ""
      },
      "allowed_artifacts": [
        "validation"
      ],
      "next_action": "run_pytest_draft",
      "batch_focus_priority": 20
    },
    "pytest_ran": {
      "user_checkpoint": null,
      "auto_safe": true,
      "agent_owner": "leaf-gui-agent",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "pytest_result",
        "ui_tree"
      ],
      "user_loop": {
        "position": "observe_safe_local_progress",
        "required_input": ""
      },
      "allowed_artifacts": [
        "pytest_result"
      ],
      "next_action": "collect_gui_context",
      "batch_focus_priority": 30
    },
    "hypium_ran": {
      "user_checkpoint": null,
      "auto_safe": true,
      "agent_owner": "leaf-gui-agent",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "hypium_result",
        "ui_tree"
      ],
      "user_loop": {
        "position": "observe_safe_local_progress",
        "required_input": ""
      },
      "allowed_artifacts": [
        "hypium_result"
      ],
      "next_action": "collect_gui_context",
      "batch_focus_priority": 30
    },
    "gui_context_collected": {
      "user_checkpoint": null,
      "auto_safe": true,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "gui_context",
        "ui_tree"
      ],
      "user_loop": {
        "position": "observe_safe_local_progress",
        "required_input": ""
      },
      "allowed_artifacts": [
        "gui_context"
      ],
      "next_action": "record_experience",
      "batch_focus_priority": 40
    },
    "experience_recorded": {
      "user_checkpoint": null,
      "auto_safe": true,
      "agent_owner": "tools.leaf_author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "experience"
      ],
      "user_loop": {
        "position": "observe_safe_local_progress",
        "required_input": ""
      },
      "allowed_artifacts": [
        "experience"
      ],
      "next_action": "export_team_knowledge",
      "batch_focus_priority": 50
    },
    "e2e_not_ready": {
      "user_checkpoint": null,
      "auto_safe": false,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "e2e_preflight_report",
        "e2e_readiness"
      ],
      "user_loop": {
        "position": "provide_target_inputs",
        "required_input": "target system app bundle or readiness evidence"
      },
      "allowed_artifacts": [
        "e2e_preflight_report",
        "e2e_readiness"
      ],
      "next_action": "prepare_haps_or_target_bundle",
      "batch_focus_priority": 70
    },
    "e2e_ready": {
      "user_checkpoint": "real_device_confirmation",
      "auto_safe": false,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "e2e_readiness",
        "target_diagnostics"
      ],
      "user_loop": {
        "position": "approve_real_device",
        "required_input": "explicit real-device approval"
      },
      "allowed_artifacts": [
        "e2e_preflight_report",
        "e2e_readiness"
      ],
      "next_action": "run_real_hypium",
      "batch_focus_priority": 80
    },
    "openharmony_synced": {
      "user_checkpoint": "manual_operator_decision",
      "auto_safe": false,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "openharmony_test_project"
      ],
      "user_loop": {
        "position": "manual_triage",
        "required_input": "decide whether to use legacy project build path"
      },
      "allowed_artifacts": [
        "openharmony_test_project"
      ],
      "next_action": "build_app_and_test_haps",
      "batch_focus_priority": 85
    },
    "openharmony_built": {
      "user_checkpoint": "manual_operator_decision",
      "auto_safe": false,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "openharmony_build",
        "package_inventory"
      ],
      "user_loop": {
        "position": "manual_triage",
        "required_input": "inspect readiness before real-device execution"
      },
      "allowed_artifacts": [
        "openharmony_build",
        "package_inventory"
      ],
      "next_action": "inspect_e2e_readiness",
      "batch_focus_priority": 86
    },
    "openharmony_build_failed": {
      "user_checkpoint": "manual_operator_decision",
      "auto_safe": false,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "openharmony_build"
      ],
      "user_loop": {
        "position": "manual_triage",
        "required_input": "inspect build failure"
      },
      "allowed_artifacts": [
        "openharmony_build"
      ],
      "next_action": "inspect_openharmony_build",
      "batch_focus_priority": 87
    },
    "complete": {
      "user_checkpoint": null,
      "auto_safe": false,
      "agent_owner": "leaf-test-author",
      "trigger_source": "workflow.json",
      "context_slice": [
        "workflow",
        "team_export_manifest"
      ],
      "user_loop": {
        "position": "done",
        "required_input": ""
      },
      "allowed_artifacts": [
        "team_export_manifest"
      ],
      "next_action": "complete",
      "batch_focus_priority": 1000
    }
  },
  "quality_gates": {
    "DRAFT_VALIDATED": "Generated pytest draft contains required traceability metadata.",
    "DRAFT_STATIC_PASS": "Host-side draft gate passed; this is not a real-device pass.",
    "CAMERA_DIRECT_SMOKE_PASS": "Built-in Camera foregrounded and UiTest layout evidence matched the Camera bundle and ability.",
    "CAMERA_CAPTURE_E2E_PASS": "Camera capture passed through UiTest shutter control and new media-file evidence.",
    "CAMERA_SMOKE_DEVICE_UNAVAILABLE": "HDC did not expose a usable OpenHarmony device.",
    "CAMERA_SMOKE_TARGET_MISSING": "No built-in Camera target candidate was found."
  }
}
